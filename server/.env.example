# Merge: 1 = comprimir (padrão: máxima compactação — HEVC + preset veryslow)
COMPRESS_VIDEO=1
# h265 = menor arquivo (recomendado). h264 = players muito antigos
COMPRESS_CODEC=h265
# veryslow = melhor compressão por qualidade (encode bem mais longo que veryfast)
COMPRESS_PRESET=veryslow
# CRF: maior = arquivo menor, menos qualidade. HEVC ~26-30; H.264 ~20-24
COMPRESS_CRF=28
# Opcionais se quiser CRF diferente por codec:
# COMPRESS_CRF_H264=23
# COMPRESS_CRF_H265=28
# Áudio (aulas): 64k costuma bastar; 96k se quiser mais fidelidade
COMPRESS_AUDIO_BITRATE=64k
# Merge: vários MP4 por sessão (altura máx em px; não upscale além da fonte). Requer COMPRESS_VIDEO=1
# MERGE_RESOLUTIONS=1080,720,480
# Legado (um arquivo session.mp4): MERGE_RESOLUTIONS=single
# FFMPEG_TIMEOUT_MS: 43200000 = 12h (vídeos longos)
# Multi-resolução: todas as saídas (ex. 1080/720/480) têm de concluir; se HEVC falhar, o merge retenta uma vez com H.264 na mesma altura.
# Merge: até N encodes em paralelo (1–4). Cuidado com CPU/RAM na VPS.
# MERGE_ENCODE_CONCURRENCY=1
# Intervalo mínimo entre gravações do JSON de progresso no disco (ms).
# MERGE_PROGRESS_THROTTLE_MS=400
# Log "[merge] Scan: …" só quando o número de streams/sessões muda (padrão). Desligar: MERGE_SCAN_SUMMARY=0
# Heartbeat periódico (ms), ex.: 3600000 = 1h: MERGE_SCAN_SUMMARY_INTERVAL_MS=3600000
# API: cache de respostas OK do nginx auth_request /check-video-access (ms). Alinhar ≥ segmento HLS (10s) + margem.
# CHECK_VIDEO_ACCESS_CACHE_MS=25000
# Após POST lesson-boundary: atrasar arranque do FFmpeg do merge (ms) para não degradar o HLS da live no mesmo host.
# LESSON_BOUNDARY_MERGE_DELAY_MS=8000
# Paralelismo ao criar hardlinks na lesson-boundary (menos = menos pico de I/O no disco das gravações).
# LESSON_BOUNDARY_LINK_CONCURRENCY=12
# API Node: auto = um worker por núcleo (máx. 32); 1 = processo único (útil em dev). Com vários workers o cache de auth é por processo — para partilhar entre réplicas use Redis (futuro).
# CLUSTER_WORKERS=auto
# MediaMTX ABR (transcode-abr.sh): GOP = duração do segmento HLS no mediamtx.yml (padrão 10s).
# HLS_GOP_SEC=10
# TRANSCODE_PRESET=superfast
# FFMPEG_THREAD_QUEUE_SIZE=4096
# API: 1 = logar também /api/check-video-access e segmentos HLS (muito ruidoso em live).
# API_LOG_ALL_REQUESTS=0
# Master ABR: prefixo absoluto das variantes no M3U8 (padrão /hls = nginx LiveBridge).
# Front Next que proxy HLS só em /api/hls/* → use LIVE_HLS_PATH_PREFIX=/api/hls (evita hls.js "Missing Target Duration" por receber HTML em /hls/...).
# LIVE_HLS_PATH_PREFIX=/hls
# Playlist por variante no master ABR (padrão main_stream.m3u8 — media playlist; hls.js precisa disto).
# index.m3u8 no MediaMTX é muitas vezes um segundo master → "Missing Target Duration" no hls.js se usares aqui.
# LIVE_HLS_VARIANT_PLAYLIST=main_stream.m3u8
# JSON (lesson-boundary, pending, status): base onde o browser chama o BFF (Spring). Docker-compose default = http://localhost:8080.
# Para só o LiveBridge (sem Java), use API_PUBLIC_BASE_URL=http://localhost:8081 ou vazio (paths relativos).
# Alternativas no pedido ao LiveBridge: X-API-Public-Base-Url, ou X-Forwarded-Host + X-Forwarded-Proto.
# O Spring ainda precisa de proxy GET /api/recordings/hls/master.m3u8 → LiveBridge (merge-progress já mapeia).
# API_PUBLIC_BASE_URL=http://localhost:8080
# Paginação GET /api/recordings?paginate=1 (max keys por pedido ListObjects R2, 1–1000).
# RECORDINGS_PAGE_MAX_KEYS=500
# Concorrência ao ler ficheiros em GET /api/recordings/pending.
# PENDING_READ_CONCURRENCY=8

# Cloudflare R2 - necessário para a API de gravações
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=livebridge

# API Java (Lessons, Vídeos) - token para X-Access-Token (mesmo valor da API Java)
# Necessário para: /api/lessons, /api/lessons/distinct/*, /api/videos, etc.
LESSONS_API_URL=http://host.docker.internal:8080
LESSONS_API_TOKEN=seu_token_x_access_token
# API_ACCESS_TOKEN=seu_token_x_access_token  # alternativa (fallback)

# Segurança: segredo compartilhado com a API Java para assinar/validar tokens de vídeo e live.
# Quando definido, gravações e live exigem token JWT obtido do Java (usuário autenticado).
# Gerar: openssl rand -hex 32
# VIDEO_ACCESS_SECRET=
# Opcional: tolerância de relógio (s) em jwt.verify. 403 em /hls/* com JWT costuma ser `exp` do token — aumentar exp no Java ou renovar cookie (init-live).
# JWT_CLOCK_TOLERANCE_SECONDS=0

# CORS: origens permitidas (separadas por vírgula). Necessário quando o frontend está em outro domínio/porta.
# Inclui o BFF PosiHub: https://api.posihub.com.br
# CORS_ORIGINS=http://localhost:3000,http://localhost:4200,https://seu-dominio.com,https://api.posihub.com.br
# Produção só 80+443 no firewall: inclui https://IP_OU_DOMINIO (sem :8081). RTMP no OBS: rtmp://IP:80/live/NOME
# O host 80 é só RTMP (MediaMTX); o site é https://... na 443. Let's Encrypt HTTP-01: usar desafio DNS ou pausar RTMP.

# --- Produção com subdomínio (quando tiveres DNS A/AAAA para a VM) ---
# Substitui `live.exemplo.com` pelo teu subdomínio real (e o domínio do front, se for diferente).
# CORS_ORIGINS=https://live.exemplo.com,https://app.exemplo.com
# API_PUBLIC_BASE_URL=https://live.exemplo.com
# No ficheiro nginx/nginx.conf, troca `server_name _;` por `server_name live.exemplo.com;` nos blocos 80/443/8080 e monta certs TLS (ex. Let's Encrypt em ./certs).

# --- Observabilidade (docker compose -f docker-compose.yml -f docker-compose.observability.yml up -d) ---
# O overlay define CLUSTER_WORKERS=1 e PROMETHEUS_METRICS=1 na API. Grafana: 3001; Prometheus: 9090;
# Alertmanager (UI local): 127.0.0.1:9093; Loki+Promtail: registo de contentores cujo nome começa por livebridge-.
# GRAFANA_ADMIN_PASSWORD=definir_no_servidor
# PROMETHEUS_METRICS=1 só é aplicado pelo overlay; não precisas duplicar no .env base.
# Alertas: ficheiro server/prometheus/alerts.yml; notificações reais: edita server/prometheus/alertmanager.yml (webhook/Slack).
