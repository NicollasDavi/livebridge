# Merge: 1 = comprimir (padrão: máxima compactação — HEVC + preset veryslow)
COMPRESS_VIDEO=1
# h265 = menor arquivo (recomendado). h264 = players muito antigos
COMPRESS_CODEC=h265
# veryslow = melhor compressão por qualidade (encode bem mais longo que veryfast)
COMPRESS_PRESET=veryslow
# CRF: maior = arquivo menor, menos qualidade. HEVC ~26-30; H.264 ~20-24
COMPRESS_CRF=28
# Opcionais se quiser CRF diferente por codec:
# COMPRESS_CRF_H264=23
# COMPRESS_CRF_H265=28
# Áudio (aulas): 64k costuma bastar; 96k se quiser mais fidelidade
COMPRESS_AUDIO_BITRATE=64k
# Merge: vários MP4 por sessão (altura máx em px; não upscale além da fonte). Requer COMPRESS_VIDEO=1
# MERGE_RESOLUTIONS=1080,720,480
# Legado (um arquivo session.mp4): MERGE_RESOLUTIONS=single
# FFMPEG_TIMEOUT_MS: 43200000 = 12h (vídeos longos)

# Cloudflare R2 - necessário para a API de gravações
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=livebridge

# API Java (Lessons, Vídeos) - token para X-Access-Token (mesmo valor da API Java)
# Necessário para: /api/lessons, /api/lessons/distinct/*, /api/videos, etc.
LESSONS_API_URL=http://host.docker.internal:8080
LESSONS_API_TOKEN=seu_token_x_access_token
# API_ACCESS_TOKEN=seu_token_x_access_token  # alternativa (fallback)

# Segurança: segredo compartilhado com a API Java para assinar/validar tokens de vídeo e live.
# Quando definido, gravações e live exigem token JWT obtido do Java (usuário autenticado).
# Gerar: openssl rand -hex 32
# VIDEO_ACCESS_SECRET=

# CORS: origens permitidas (separadas por vírgula). Necessário quando o frontend está em outro domínio/porta.
# CORS_ORIGINS=http://localhost:3000,http://localhost:4200,https://seu-dominio.com
