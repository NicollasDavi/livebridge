# Merge: 1 = comprimir. veryfast + CRF 23 = rápido + arquivo menor
COMPRESS_VIDEO=1
COMPRESS_PRESET=veryfast
COMPRESS_CRF=23
# FFMPEG_TIMEOUT_MS: 43200000 = 12h (vídeos ~2h)
# CRF: 18-23 (menor = melhor qualidade). 20 = bom para aulas, arquivos menores
COMPRESS_CRF=20

# Cloudflare R2 - necessário para a API de gravações
R2_ACCOUNT_ID=seu_account_id
R2_ACCESS_KEY=sua_access_key
R2_SECRET_KEY=sua_secret_key
R2_BUCKET=livebridge
