R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET=livebridge

# API Lessons (Java) - metadata das aulas
# Local: http://host.docker.internal:8080  |  Produção: https://api.posihub.com.br
LESSONS_API_URL=http://host.docker.internal:8080
# Token para X-Access-Token — MESMO valor que API_ACCESS_TOKEN / api.access.token na API Java.
# Dev local: o perfil Spring "dev" usa por omissão "dev-livebridge-lessons-token" (ver application-dev.properties).
LESSONS_API_TOKEN=dev-livebridge-lessons-token
# API_ACCESS_TOKEN=dev-livebridge-lessons-token
# SKIP_LESSONS_API=0  # descomente para buscar lessons na listagem (padrão: só R2)

PORT=3000

# Control API MediaMTX (GET /api/live/transmissoes). No Docker o padrão é http://mediamtx:9997
# MEDIAMTX_CONTROL_API_URL=http://mediamtx:9997
# MEDIAMTX_HTTP_TIMEOUT_MS=8000
# Cache da lista de paths no MediaMTX (ms). 0 = desligar.
# MEDIAMTX_PATHS_CACHE_MS=3000
